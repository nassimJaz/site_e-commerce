{% extends 'base.html.twig' %}

{% block title %}LUXE SAC — Maroquinerie de Luxe{% endblock %}

{% block body %}
{# Hero Banner #}
<section class="hero-section mb-5">
    <div class="hero-overlay"></div>
    <div class="hero-content text-center">
        <h1 class="hero-title">L'Élégance au Quotidien</h1>
        <p class="hero-subtitle">Découvrez notre collection exclusive de sacs à main, alliant raffinement et savoir-faire artisanal.</p>
        <a href="{{ path('app_boutique') }}" class="btn btn-luxe btn-lg mt-3">
            Découvrir la Collection <i class="bi bi-arrow-right ms-2"></i>
        </a>
    </div>
</section>

{# Avantages #}
<section class="advantages-section mb-5">
    <div class="row text-center g-4">
        <div class="col-md-4">
            <div class="advantage-card p-4">
                <i class="bi bi-truck advantage-icon"></i>
                <h6 class="mt-3">Livraison Offerte</h6>
                <small class="text-muted">Dès 150€ d'achat</small>
            </div>
        </div>
        <div class="col-md-4">
            <div class="advantage-card p-4">
                <i class="bi bi-shield-check advantage-icon"></i>
                <h6 class="mt-3">Qualité Garantie</h6>
                <small class="text-muted">Cuir véritable premium</small>
            </div>
        </div>
        <div class="col-md-4">
            <div class="advantage-card p-4">
                <i class="bi bi-arrow-return-left advantage-icon"></i>
                <h6 class="mt-3">Retours Gratuits</h6>
                <small class="text-muted">Sous 30 jours</small>
            </div>
        </div>
    </div>
</section>

{# Produits vedettes #}
{% if featuredProducts|length > 0 %}
<section class="featured-section mb-5">
    <div class="text-center mb-5">
        <h2 class="section-title">Nos Coups de Cœur</h2>
        <div class="section-divider"></div>
        <p class="section-subtitle">Les pièces favorites de notre collection</p>
    </div>

    <div class="row g-4">
        {% for product in featuredProducts %}
        <div class="col-md-6 col-lg-3">
            <div class="product-card">
                <a href="{{ path('app_product_show', {id: product.id}) }}" class="product-card-link">
                    <div class="product-image-wrapper">
                        <img src="/images/products/{{ product.image }}" alt="{{ product.title }}" class="product-image" loading="lazy">
                        <div class="product-overlay">
                            <span class="product-overlay-text">Voir le détail</span>
                        </div>
                    </div>
                </a>
                <div class="product-info">
                    <span class="product-category">{{ product.category }}</span>
                    <h5 class="product-title">
                        <a href="{{ path('app_product_show', {id: product.id}) }}">{{ product.title }}</a>
                    </h5>
                    <div class="product-bottom">
                        <span class="product-price">{{ product.price|number_format(2, ',', ' ') }} €</span>
                        <form action="{{ path('app_cart_add', {id: product.id}) }}" method="POST" class="d-inline">
                            <button type="submit" class="btn btn-add-cart" title="Ajouter au panier">
                                <i class="bi bi-bag-plus"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

    <div class="text-center mt-5">
        <a href="{{ path('app_boutique') }}" class="btn btn-luxe-outline btn-lg">
            Voir toute la Boutique <i class="bi bi-arrow-right ms-2"></i>
        </a>
    </div>
</section>
{% endif %}
{% endblock %}
