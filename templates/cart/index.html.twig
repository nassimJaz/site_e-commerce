{% extends 'base.html.twig' %}

{% block title %}Mon Panier — LUXE SAC{% endblock %}

{% block body %}
<section class="py-3">
    <h1 class="section-title mb-4">Mon Panier</h1>
    <div class="section-divider mb-5" style="margin-left: 0;"></div>

    {% if cart|length > 0 %}
    <div class="row g-5">
        {# Tableau panier #}
        <div class="col-lg-8">
            <div class="cart-table">
                {% for item in cart %}
                <div class="cart-item">
                    <div class="cart-item-image">
                        <a href="{{ path('app_product_show', {id: item.product.id}) }}">
                            <img src="/images/products/{{ item.product.image }}" alt="{{ item.product.title }}">
                        </a>
                    </div>
                    <div class="cart-item-details">
                        <h6 class="cart-item-title">
                            <a href="{{ path('app_product_show', {id: item.product.id}) }}">{{ item.product.title }}</a>
                        </h6>
                        <span class="product-category">{{ item.product.category }}</span>
                        <p class="cart-item-price mt-1">{{ item.product.price|number_format(2, ',', ' ') }} €</p>
                    </div>
                    <div class="cart-item-quantity">
                        <div class="quantity-controls">
                            <form action="{{ path('app_cart_decrement', {id: item.product.id}) }}" method="POST" class="d-inline">
                                <button type="submit" class="btn btn-quantity">
                                    <i class="bi bi-dash"></i>
                                </button>
                            </form>
                            <span class="quantity-value">{{ item.quantity }}</span>
                            <form action="{{ path('app_cart_increment', {id: item.product.id}) }}" method="POST" class="d-inline">
                                <button type="submit" class="btn btn-quantity">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                    <div class="cart-item-subtotal">
                        <span class="subtotal-price">{{ (item.product.price * item.quantity)|number_format(2, ',', ' ') }} €</span>
                    </div>
                    <div class="cart-item-remove">
                        <form action="{{ path('app_cart_remove', {id: item.product.id}) }}" method="POST">
                            <button type="submit" class="btn btn-remove" title="Supprimer">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </form>
                    </div>
                </div>
                {% endfor %}
            </div>

            <div class="mt-3">
                <form action="{{ path('app_cart_clear') }}" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-luxe-outline btn-sm">
                        <i class="bi bi-x-circle me-1"></i> Vider le panier
                    </button>
                </form>
            </div>
        </div>

        {# Résumé commande #}
        <div class="col-lg-4">
            <div class="cart-summary">
                <h5 class="cart-summary-title">Récapitulatif</h5>
                <hr style="border-color: var(--luxe-gold); opacity: 0.2;">
                <div class="d-flex justify-content-between mb-2">
                    <span>Sous-total</span>
                    <span>{{ total|number_format(2, ',', ' ') }} €</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Livraison</span>
                    <span>{% if total >= 150 %}<span class="text-success">Offerte</span>{% else %}9,90 €{% endif %}</span>
                </div>
                <hr style="border-color: var(--luxe-gold); opacity: 0.2;">
                <div class="d-flex justify-content-between cart-total">
                    <strong>Total</strong>
                    <strong>{{ (total >= 150 ? total : total + 9.90)|number_format(2, ',', ' ') }} €</strong>
                </div>

                {% if total < 150 %}
                <div class="free-shipping-notice mt-3">
                    <i class="bi bi-info-circle me-1"></i>
                    Plus que {{ (150 - total)|number_format(2, ',', ' ') }} € pour la livraison offerte !
                </div>
                {% endif %}

                <button class="btn btn-luxe w-100 mt-4 btn-lg" disabled>
                    <i class="bi bi-lock me-2"></i>Commander
                </button>
                <small class="text-muted d-block text-center mt-2">Paiement sécurisé — Bientôt disponible</small>
            </div>
        </div>
    </div>
    {% else %}
    <div class="text-center py-5">
        <i class="bi bi-bag" style="font-size: 4rem; color: var(--luxe-gold); opacity: 0.5;"></i>
        <h4 class="mt-3" style="font-family: var(--font-heading);">Votre panier est vide</h4>
        <p class="text-muted">Découvrez notre collection et trouvez le sac parfait.</p>
        <a href="{{ path('app_boutique') }}" class="btn btn-luxe btn-lg mt-2">
            Découvrir la Boutique <i class="bi bi-arrow-right ms-2"></i>
        </a>
    </div>
    {% endif %}
</section>
{% endblock %}
