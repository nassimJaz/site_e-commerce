{% extends 'base.html.twig' %}

{% block title %}{{ product.title }} — LUXE SAC{% endblock %}
{% block meta_description %}{{ product.description|slice(0, 160) }}{% endblock %}

{% block body %}
<section class="py-3">
    {# Breadcrumb #}
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_boutique') }}">Boutique</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ product.title }}</li>
        </ol>
    </nav>

    <div class="row g-5">
        {# Image produit #}
        <div class="col-lg-6">
            <div class="product-detail-image-wrapper">
                <img src="/images/products/{{ product.image }}" alt="{{ product.title }}" class="product-detail-image">
            </div>
        </div>

        {# Informations produit #}
        <div class="col-lg-6">
            <span class="product-category mb-2 d-inline-block">{{ product.category }}</span>
            <h1 class="product-detail-title">{{ product.title }}</h1>
            <p class="product-detail-price">{{ product.price|number_format(2, ',', ' ') }} €</p>

            <hr class="my-4" style="border-color: var(--luxe-gold); opacity: 0.3;">

            <p class="product-detail-description">{{ product.description }}</p>

            {# Stock #}
            <div class="mb-4">
                {% if product.stock > 3 %}
                    <span class="text-success"><i class="bi bi-check-circle me-1"></i> En stock</span>
                {% elseif product.stock > 0 %}
                    <span class="text-warning"><i class="bi bi-exclamation-circle me-1"></i> Plus que {{ product.stock }} en stock</span>
                {% else %}
                    <span class="text-danger"><i class="bi bi-x-circle me-1"></i> Rupture de stock</span>
                {% endif %}
            </div>

            {# Bouton ajout au panier #}
            {% if product.stock > 0 %}
            <form action="{{ path('app_cart_add', {id: product.id}) }}" method="POST">
                <button type="submit" class="btn btn-luxe btn-lg w-100">
                    <i class="bi bi-bag-plus me-2"></i>Ajouter au Panier
                </button>
            </form>
            {% else %}
            <button class="btn btn-secondary btn-lg w-100" disabled>
                Produit indisponible
            </button>
            {% endif %}

            {# Avantages #}
            <div class="mt-4 product-perks">
                <div class="d-flex align-items-center mb-2">
                    <i class="bi bi-truck me-3 perk-icon"></i>
                    <small>Livraison offerte dès 150€</small>
                </div>
                <div class="d-flex align-items-center mb-2">
                    <i class="bi bi-arrow-return-left me-3 perk-icon"></i>
                    <small>Retours gratuits sous 30 jours</small>
                </div>
                <div class="d-flex align-items-center">
                    <i class="bi bi-shield-check me-3 perk-icon"></i>
                    <small>Garantie authenticité</small>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
