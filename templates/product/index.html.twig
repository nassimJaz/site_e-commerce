{% extends 'base.html.twig' %}

{% block title %}Boutique — LUXE SAC{% endblock %}

{% block body %}
<section class="py-3">
    <div class="text-center mb-5">
        <h1 class="section-title">Notre Collection</h1>
        <div class="section-divider"></div>
        <p class="section-subtitle">Des sacs d'exception pour toutes les occasions</p>
    </div>

    {# Filtre par catégorie #}
    <div class="category-filter mb-4 text-center">
        <a href="{{ path('app_boutique') }}" class="btn {% if currentCategory is null %}btn-luxe{% else %}btn-luxe-outline{% endif %} btn-sm me-2 mb-2">
            Tous
        </a>
        {% for cat in categories %}
            <a href="{{ path('app_boutique', {category: cat}) }}" class="btn {% if currentCategory == cat %}btn-luxe{% else %}btn-luxe-outline{% endif %} btn-sm me-2 mb-2">
                {{ cat }}
            </a>
        {% endfor %}
    </div>

    {# Grille de produits #}
    {% if products|length > 0 %}
    <div class="row g-4">
        {% for product in products %}
        <div class="col-md-6 col-lg-3">
            <div class="product-card">
                <a href="{{ path('app_product_show', {id: product.id}) }}" class="product-card-link">
                    <div class="product-image-wrapper">
                        <img src="/images/products/{{ product.image }}" alt="{{ product.title }}" class="product-image" loading="lazy">
                        <div class="product-overlay">
                            <span class="product-overlay-text">Voir le détail</span>
                        </div>
                        {% if product.stock <= 3 and product.stock > 0 %}
                            <span class="product-badge badge-limited">Plus que {{ product.stock }} !</span>
                        {% elseif product.stock == 0 %}
                            <span class="product-badge badge-sold-out">Rupture</span>
                        {% endif %}
                    </div>
                </a>
                <div class="product-info">
                    <span class="product-category">{{ product.category }}</span>
                    <h5 class="product-title">
                        <a href="{{ path('app_product_show', {id: product.id}) }}">{{ product.title }}</a>
                    </h5>
                    <div class="product-bottom">
                        <span class="product-price">{{ product.price|number_format(2, ',', ' ') }} €</span>
                        {% if product.stock > 0 %}
                        <form action="{{ path('app_cart_add', {id: product.id}) }}" method="POST" class="d-inline">
                            <button type="submit" class="btn btn-add-cart" title="Ajouter au panier">
                                <i class="bi bi-bag-plus"></i>
                            </button>
                        </form>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% else %}
    <div class="text-center py-5">
        <i class="bi bi-bag-x" style="font-size: 3rem; color: var(--luxe-gold);"></i>
        <p class="mt-3 text-muted">Aucun produit trouvé dans cette catégorie.</p>
        <a href="{{ path('app_boutique') }}" class="btn btn-luxe-outline mt-2">Voir tous les produits</a>
    </div>
    {% endif %}
</section>
{% endblock %}
