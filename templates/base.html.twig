<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}LUXE SAC — Maroquinerie de Luxe{% endblock %}</title>
        <meta name="description" content="{% block meta_description %}Découvrez notre collection exclusive de sacs à main de luxe. Élégance, qualité et style au rendez-vous.{% endblock %}">
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>👜</text></svg>">

        {# Google Fonts #}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

        {# Bootstrap 5 CSS #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

        {# Bootstrap Icons #}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
        {% endblock %}
    </head>
    <body class="d-flex flex-column min-vh-100">
        <header>
            {# Top bar #}
            <div class="top-bar text-center py-2">
                <small>✨ Livraison offerte dès 150€ d'achat ✨</small>
            </div>

            <nav class="navbar navbar-expand-lg navbar-luxe shadow-sm">
                <div class="container">
                    <a class="navbar-brand brand-logo" href="{{ path('app_home') }}">
                        <span class="brand-icon">👜</span>LUXE SAC
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarNav">
                        <ul class="navbar-nav me-auto">
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') == 'app_home' %}active{% endif %}" href="{{ path('app_home') }}">Accueil</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') == 'app_boutique' %}active{% endif %}" href="{{ path('app_boutique') }}">Boutique</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') == 'app_contact' %}active{% endif %}" href="{{ path('app_contact') }}">Contact</a>
                            </li>
                        </ul>
                        <a href="{{ path('app_cart') }}" class="btn btn-cart position-relative" id="cart-button">
                            <i class="bi bi-bag"></i>
                            {% set cartCount = app.session.get('cart')|default([])|reduce((carry, v) => carry + v, 0) %}
                            {% if cartCount > 0 %}
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill badge-cart">
                                    {{ cartCount }}
                                </span>
                            {% endif %}
                        </a>
                    </div>
                </div>
            </nav>
        </header>

        <main class="flex-shrink-0">
            <div class="container mt-4">
                {# Flash messages #}
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label == 'success' ? 'success' : (label == 'error' ? 'danger' : 'info') }} alert-dismissible fade show" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}
                {% endfor %}

                {% block body %}{% endblock %}
            </div>
        </main>

        <footer class="footer-luxe mt-auto py-5">
            <div class="container">
                <div class="row">
                    <div class="col-md-4 mb-4 mb-md-0">
                        <h5 class="footer-brand">👜 LUXE SAC</h5>
                        <p class="footer-text">Maroquinerie de luxe. Élégance et raffinement depuis 2024.</p>
                    </div>
                    <div class="col-md-4 mb-4 mb-md-0">
                        <h6 class="footer-heading">Navigation</h6>
                        <ul class="list-unstyled footer-links">
                            <li><a href="{{ path('app_home') }}">Accueil</a></li>
                            <li><a href="{{ path('app_boutique') }}">Boutique</a></li>
                            <li><a href="{{ path('app_contact') }}">Contact</a></li>
                        </ul>
                    </div>
                    <div class="col-md-4">
                        <h6 class="footer-heading">Informations</h6>
                        <ul class="list-unstyled footer-links">
                            <li><i class="bi bi-geo-alt me-2"></i>Paris, France</li>
                            <li><i class="bi bi-envelope me-2"></i>contact@luxesac.fr</li>
                            <li><i class="bi bi-telephone me-2"></i>+33 1 23 45 67 89</li>
                        </ul>
                    </div>
                </div>
                <hr class="footer-divider">
                <div class="text-center">
                    <small class="footer-copyright">© {{ "now"|date("Y") }} LUXE SAC — Tous droits réservés</small>
                </div>
            </div>
        </footer>
    </body>
</html>
